<!-- Shoppable Video Theme App Block -->
{% schema
{
  "name": "Shoppable Video",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "video_id",
      "label": "Video ID",
      "placeholder": "gid://shopify/MetaobjectInstance/..."
    },
    {
      "type": "select",
      "id": "player_size",
      "label": "Player Size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ]
}
{% endschema %}

<div id="shoppable-video-container" class="shoppable-video-root" data-video-id="{{ section.settings.video_id }}">
  <div class="sv-loading">Loading video...</div>
</div>

<style>
  .shoppable-video-root {
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
  }

  .sv-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 9 / 16;
    background: #f0f1f4;
    border-radius: 8px;
    color: #6b7280;
    font-size: 14px;
  }

  .sv-player {
    position: relative;
    aspect-ratio: 9 / 16;
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .sv-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sv-hotspot {
    position: absolute;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: white;
    border: 3px solid #2b6cb0;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .sv-hotspot:hover {
    transform: scale(1.2);
  }

  .sv-product-card {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    background: rgba(255, 255, 255, 0.96);
    border-radius: 10px;
    padding: 10px;
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .sv-product-image {
    width: 44px;
    height: 44px;
    background: #e5e7eb;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .sv-product-meta {
    flex: 1;
  }

  .sv-product-title {
    font-size: 13px;
    font-weight: 600;
    margin: 0;
  }

  .sv-product-price {
    font-size: 12px;
    color: #6b7280;
    margin: 4px 0 0;
  }

  .sv-add-to-cart {
    background: #111;
    color: white;
    font-size: 11px;
    padding: 6px 10px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }

  .sv-add-to-cart:hover {
    background: #333;
  }

  .sv-unavailable {
    color: #ef4444;
    font-size: 11px;
  }
</style>

<script src="{{ 'shoppable-video.js' | asset_url }}" defer="defer"></script>
